# Shopify app credentials (Partner Dashboard -> App -> API credentials)
SHOPIFY_API_KEY=shopify_api_key_here
SHOPIFY_API_SECRET=shopify_api_secret_here

# Public URL where this app is hosted
SHOPIFY_APP_URL=https://iagents-shopify-auth.98uxik.easypanel.host

# Scopes (must match shopify.app.tiendamobitat.toml)
SCOPES=write_products,read_products,write_metaobjects,write_metaobject_definitions,read_inventory,read_checkouts,write_checkouts,read_orders

# Endpoint to receive offline access tokens after install / uninstall events
TOKEN_NOTIFY_URL=https://api.iagents.pro/webhook/shopify-access-token-response

# Postgres (runs as the `db` service in docker-compose; app reaches it at hostname `db`)
POSTGRES_USER=iagents
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=iagents

# Public port exposed by docker-compose for the app (only relevant for the host)
APP_PORT=3000

# DATABASE_URL is built automatically by docker-compose from the POSTGRES_* vars above.
# Only set this manually if you run the app outside docker-compose:
# DATABASE_URL=postgresql://iagents:change_me_strong_password@db:5432/iagents
