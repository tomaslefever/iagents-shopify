# Shopify app credentials (Partner Dashboard -> App -> API credentials)
SHOPIFY_API_KEY=c27436a8a382d3d3d3d4736ab102021a
SHOPIFY_API_SECRET=

# Public URL where this app is hosted
SHOPIFY_APP_URL=https://iagents-shopify-auth.98uxik.easypanel.host

# Scopes (must match shopify.app.tiendamobitat.toml)
SCOPES=write_products,read_products,write_metaobjects,write_metaobject_definitions,read_inventory,read_checkouts,write_checkouts,read_orders

# Postgres connection string (e.g. Supabase, Neon, Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Endpoint to receive offline access tokens after install / uninstall events
TOKEN_NOTIFY_URL=https://api.iagents.pro/webhook/shopify-access-token-response
